PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

MONGODB_URI=mongodb://127.0.0.1:27017/homelink

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

OTP_EXPIRES_MINUTES=10
LOCATION_PROVIDER=nominatim
LOCATION_SEARCH_API=https://nominatim.openstreetmap.org/search
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_COUNTRY=ng
GOOGLE_PLACES_LANGUAGE=en
GOOGLE_PLACES_LIMIT=8

# Optional — omit both vars for a provider to disable that OAuth route.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3000/auth/facebook/callback

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=homelink
